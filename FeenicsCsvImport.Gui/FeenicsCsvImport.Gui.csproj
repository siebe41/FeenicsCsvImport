  <!-- GitVersion: stamp assemblies and capture version for zip naming -->
  <!-- Get SemVer from GitVersion for zip naming -->
  <Target Name="GetGitVersion" BeforeTargets="PackageZip">
    <Exec Command="dotnet-gitversion /showvariable SemVer" ConsoleToMsBuild="true" IgnoreExitCode="true">
      <Output TaskParameter="ConsoleOutput" PropertyName="GitVersion_SemVer" />
    </Exec>
    <PropertyGroup>
      <GitVersion_SemVer Condition="'$(GitVersion_SemVer)' == ''">0.0.0</GitVersion_SemVer>
    </PropertyGroup>
    <Message Importance="high" Text="GitVersion SemVer: $(GitVersion_SemVer)" />
  </Target>
  <!-- Tag and push version after successful Release build -->
  <Target Name="GitTagAndPush" AfterTargets="PackageZip" Condition="'$(Configuration)' == 'Release'">
    <!-- Only tag if the tag doesn't already exist -->
    <Exec Command="git tag v$(GitVersion_SemVer)" IgnoreExitCode="true" />
    <Exec Command="git push origin v$(GitVersion_SemVer)" IgnoreExitCode="true" />
    <Message Importance="high" Text="Tagged and pushed: v$(GitVersion_SemVer)" />
  </Target>
  <!-- Package zip in Release builds -->
  <Target Name="PackageZip" AfterTargets="Build" Condition="'$(Configuration)' == 'Release'">
    <PropertyGroup>
      <ZipStagingDir>$(OutputPath)ZipStaging\</ZipStagingDir>
      <ZipVersionSuffix Condition="'$(GitVersion_SemVer)' != ''">-$(GitVersion_SemVer)</ZipVersionSuffix>
      <ZipVersionSuffix Condition="'$(GitVersion_SemVer)' == ''">-0.0.0</ZipVersionSuffix>
      <ZipOutputFile>$(OutputPath)FeenicsCsvImport$(ZipVersionSuffix).zip</ZipOutputFile>
    </PropertyGroup>
    <!-- Clean previous staging -->
    <RemoveDir Directories="$(ZipStagingDir)" />
    <MakeDir Directories="$(ZipStagingDir)" />
    <!-- Collect runtime files -->
    <ItemGroup>
      <_ZipDlls Include="$(OutputPath)*.dll" />
      <_ZipConfig Include="$(OutputPath)$(AssemblyName).exe.config" />
    </ItemGroup>
    <!-- Copy dlls and config -->
    <Copy SourceFiles="@(_ZipDlls)" DestinationFolder="$(ZipStagingDir)" />
    <Copy SourceFiles="@(_ZipConfig)" DestinationFolder="$(ZipStagingDir)" Condition="Exists('$(OutputPath)$(AssemblyName).exe.config')" />
    <!-- Copy exe renamed to Start.exe -->
    <Copy SourceFiles="$(OutputPath)$(AssemblyName).exe" DestinationFiles="$(ZipStagingDir)Start.exe" />
    <!-- Create zip -->
    <Delete Files="$(ZipOutputFile)" Condition="Exists('$(ZipOutputFile)')" />
    <ZipDirectory SourceDirectory="$(ZipStagingDir)" DestinationFile="$(ZipOutputFile)" />
    <!-- Clean up staging -->
    <RemoveDir Directories="$(ZipStagingDir)" />
  </Target>
