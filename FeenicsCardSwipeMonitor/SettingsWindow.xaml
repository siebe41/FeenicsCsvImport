<Window x:Class="FeenicsCardSwipeMonitor.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Badge Reader Configuration" Height="700" Width="450" 
        WindowStartupLocation="CenterScreen" Background="#F0F0F0" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Connection Settings" FontSize="20" FontWeight="SemiBold" Foreground="#333"/>
            <TextBlock Text="Configure the clubhouse reader and Feenics API credentials." FontSize="12" Foreground="#666"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Label Content="Acre/Feenics Instance Name" FontWeight="Medium"/>
                <TextBox x:Name="TxtInstance" Margin="0,2,0,12" Padding="5"/>

                <Label Content="API Username" FontWeight="Medium"/>
                <TextBox x:Name="TxtUser" Margin="0,2,0,12" Padding="5"/>

                <Label Content="API Password" FontWeight="Medium"/>
                <PasswordBox x:Name="TxtPass" Margin="0,2,0,12" Padding="5"/>

                <CheckBox x:Name="ChkLogToFeenics" Content="Enable Feenics API Logging" 
                          IsChecked="True" FontWeight="Medium" Margin="0,5,0,12" 
                          Foreground="#333" VerticalContentAlignment="Center"/>
                
                <Separator Margin="0,5,0,15"/>

                <Label Content="Reader COM Port &amp; Serial Settings" FontWeight="Medium"/>
                <StackPanel Orientation="Horizontal" Margin="0,2,0,5">
                    <ComboBox x:Name="CmbCom" Width="100" Padding="5" VerticalContentAlignment="Center" IsEditable="True"/>
                    <Button x:Name="BtnRefreshPorts" Content="↻" Width="28" Height="28" Margin="5,0,0,0" Click="BtnRefreshPorts_Click" ToolTip="Refresh Ports" Background="#E1E1E1"/>
                    <TextBlock Text="Select or type port (e.g. COM3)." Margin="10,0,0,0" VerticalAlignment="Center" FontSize="11" FontStyle="Italic" Foreground="#888"/>
                </StackPanel>

                <Grid Margin="0,5,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                        <TextBlock Text="Baud Rate" FontSize="11" Foreground="#666" Margin="0,0,0,2"/>
                        <ComboBox x:Name="CmbBaud" Padding="3"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,5,0">
                        <TextBlock Text="Data Bits" FontSize="11" Foreground="#666" Margin="0,0,0,2"/>
                        <ComboBox x:Name="CmbDataBits" Padding="3"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="0,0,5,0">
                        <TextBlock Text="Parity" FontSize="11" Foreground="#666" Margin="0,0,0,2"/>
                        <ComboBox x:Name="CmbParity" Padding="3"/>
                    </StackPanel>
                    <StackPanel Grid.Column="3">
                        <TextBlock Text="Stop Bits" FontSize="11" Foreground="#666" Margin="0,0,0,2"/>
                        <ComboBox x:Name="CmbStopBits" Padding="3"/>
                    </StackPanel>
                </Grid>

                <Separator Margin="0,15,0,10"/>

                <Label Content="Simulate Badge Scan" FontWeight="Medium"/>
                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="TxtSimBadge" Width="150" Padding="5" VerticalContentAlignment="Center"/>
                    <Button x:Name="BtnSimulate" Content="Simulate Scan" Width="110" Height="28" Margin="10,0,0,0" Click="BtnSimulate_Click" Background="#E1E1E1"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <TextBox x:Name="TxtStatus" Grid.Row="2" Height="60" Margin="0,10,0,0" IsReadOnly="True"
                 VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" FontSize="11"
                 Background="#FAFAFA" Foreground="#333" BorderBrush="#CCC" Padding="5"/>

        <Grid Grid.Row="3" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="BtnCheckUpdate" Grid.Column="0" Content="Check for Updates" Width="120" Height="32" Click="BtnCheckUpdate_Click" Background="Transparent" BorderBrush="#CCC"/>

            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnTest" Content="Test Connection" Width="120" Height="32" Margin="0,0,10,0" Click="BtnTest_Click" Background="#E1E1E1"/>
                <Button x:Name="BtnSave" Content="Save &amp; Encrypt" Width="120" Height="32" Click="BtnSave_Click" Background="#007ACC" Foreground="White" FontWeight="SemiBold"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
